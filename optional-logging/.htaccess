# Nano GDPR - protect the consent log.
# Stops the public opening nano-gdpr-log.txt from the web.

<Files "nano-gdpr-log.txt">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</Files>
